# eBay API Credentials (REQUIRED)
# Create an app at https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=your_client_id_here
EBAY_CLIENT_SECRET=your_client_secret_here

# The full callback URL you registered in your eBay app (RuName)
# Must match exactly what you set in eBay Developer Portal
EBAY_REDIRECT_URI=http://localhost:3000/auth/callback

# Set to 'sandbox' for testing, 'production' for live
EBAY_ENV=production

# Security - CHANGE THIS in production
SESSION_SECRET=change-this-to-a-long-random-string

# URLs (update for your deployment)
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
